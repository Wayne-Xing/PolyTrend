.whale-card {
  border: 1px solid #dce4ee;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(21, 101, 192, 0.08);
  border-radius: 24rpx;
  overflow: hidden;
}

.whale-card__cover {
  position: relative;
  height: 160rpx;
  background-size: cover;
  background-position: center;
  display: flex;
  align-items: flex-end;
  padding: 14rpx;
  box-sizing: border-box;
}

.whale-card__fav-top {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  z-index: 2;
  width: 38rpx;
  height: 38rpx;
  border-radius: 999rpx;
  border: 1px solid rgba(255, 255, 255, 0.56);
  background: rgba(8, 17, 33, 0.36);
  color: #f8fbff;
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.whale-card__fav-top--active {
  color: #ff5d7f;
  background: rgba(255, 255, 255, 0.9);
  border-color: rgba(255, 255, 255, 0.92);
}

.whale-card__cover-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(8, 17, 33, 0.1) 0%, rgba(8, 17, 33, 0.6) 100%);
}

.whale-card__cover-title {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  max-width: 100%;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #203047;
  font-size: 20rpx;
  font-weight: 700;
}

.whale-card__body {
  padding: 18rpx;
}

.whale-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.whale-card__amount {
  color: #0f4a9d;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1;
}

.whale-card__time {
  margin-top: 8rpx;
  color: #72869d;
  font-size: 20rpx;
}

.whale-card__side {
  min-width: 102rpx;
  height: 52rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.whale-card__side--buy {
  color: #167b3f;
  background: #e8f7ed;
}

.whale-card__side--sell {
  color: #bb2b2b;
  background: #feeff2;
}

.whale-card__market {
  margin-top: 14rpx;
  color: #1d2f45;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.4;
}

.whale-card__line {
  margin-top: 6rpx;
  color: #5e748c;
  font-size: 22rpx;
}

.whale-card__footer {
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1px solid #edf2f7;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.whale-card__address {
  flex: 1;
  min-width: 0;
  color: #5e748c;
  font-size: 20rpx;
}

.whale-card__link {
  color: #1565c0;
  font-size: 22rpx;
  font-weight: 600;
}
