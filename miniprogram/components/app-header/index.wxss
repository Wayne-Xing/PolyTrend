.app-header {
  padding-right: 24rpx;
  padding-bottom: 14rpx;
  padding-left: 24rpx;
  background: linear-gradient(135deg, #0f4a9d 0%, #1565c0 64%, #2d7dd2 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(21, 101, 192, 0.24);
}

.app-header__brand-row {
  display: flex;
  justify-content: center;
  align-items: center;
}

.app-header__brand-wrap {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

.app-header__brand-logo {
  width: 38rpx;
  height: 38rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(222, 237, 255, 0.9));
  color: #0f4a9d;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 800;
}

.app-header__brand-title {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.2rpx;
}

.app-header__brand-tag {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
  line-height: 1;
}

.app-header__brand-tag-top {
  font-size: 12rpx;
  font-weight: 700;
  opacity: 0.95;
}

.app-header__brand-tag-bottom {
  margin-top: 2rpx;
  font-size: 10rpx;
  opacity: 0.82;
}

.app-header__row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.app-header__left {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.app-header__left--back-only {
  gap: 0;
}

.app-header__back-text {
  display: inline-flex;
  align-items: center;
  max-width: 220rpx;
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  border: 1px solid rgba(255, 255, 255, 0.56);
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
}

.app-header__back-icon {
  width: 28rpx;
  height: 28rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 700;
  opacity: 0.96;
  flex-shrink: 0;
}

.app-header__section-logo {
  width: 28rpx;
  height: 28rpx;
  border-radius: 7rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(222, 237, 255, 0.9));
  color: #0f4a9d;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 12rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.app-header__section {
  min-width: 0;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.app-header__lang-text {
  flex-shrink: 0;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.1;
  opacity: 0.96;
}
