<view class="login-page">
  <view class="login-header">
    <t-avatar size="80rpx">PA</t-avatar>
    <view class="login-title">PolyTrend</view>
    <view class="login-subtitle">PolyMarket 资讯速递小程序</view>
    <t-tag theme="primary" variant="light">v1.0 原型</t-tag>
  </view>

  <view class="login-card">
    <view class="section-title">微信登录流程</view>
    <t-steps current="{{current}}" readonly="{{true}}" layout="vertical">
      <t-step-item title="进入小程序" content="未登录用户展示授权登录引导页" />
      <t-step-item title="获取 code" content="点击微信一键登录，调用 wx.login()" />
      <t-step-item title="云函数认证" content="发送 code 到 getUserInfo，换取 openid" />
      <t-step-item title="登录成功" content="进入主页并展示头像昵称" />
    </t-steps>
  </view>

  <view class="login-btns">
    <t-button theme="primary" block="{{true}}" size="large" bind:tap="onLogin">微信一键登录</t-button>
    <view style="height: 16rpx;"></view>
    <t-button variant="outline" block="{{true}}" size="large" bind:tap="onSkip">先看看热点数据</t-button>
  </view>

  <t-divider content="登录即同意《用户协议》与《隐私政策》" />
</view>
