.login-page {
  min-height: 100vh;
  background: radial-gradient(circle at top, #d8e9ff 0%, #f5f7fa 42%, #f5f7fa 100%);
  padding: 60rpx 28rpx 40rpx;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 36rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1f3f75;
}

.login-subtitle {
  font-size: 26rpx;
  color: #6a7f9b;
}

.login-card {
  border-radius: 24rpx;
  background: #ffffff;
  padding: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(21, 101, 192, 0.08);
}

.login-btns {
  margin-top: 36rpx;
  margin-bottom: 16rpx;
}
