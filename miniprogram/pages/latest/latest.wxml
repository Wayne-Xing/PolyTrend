<view class="page-shell">
  <t-navbar title="🆕 最新 New" fixed="{{true}}" placeholder="{{true}}" />

  <view class="content-wrap">
    <view class="top-info">
      <text class="top-clock">{{clockText}}</text>
      <t-button size="small" variant="outline" theme="primary" class="top-lang" bind:tap="onToggleLang">{{langBtnText}}</t-button>
    </view>

    <view class="section-title">24 小时新上线市场</view>

    <block wx:for="{{events}}" wx:key="id">
      <view class="event-card" bind:tap="onOpenDetail" data-title="{{item.title}}">
        <t-image class="event-cover" src="{{item.image}}" mode="aspectFill" lazy="{{true}}" />
        <view class="event-body">
          <view class="event-title">{{item.title}}</view>

          <view class="event-meta">
            <t-tag class="meta-tag" size="small" theme="primary" variant="light">{{item.category}}</t-tag>
            <t-tag class="meta-tag" size="small" variant="light">{{item.deadline}}</t-tag>
            <t-tag class="meta-tag" size="small" variant="light">💧 {{item.liquidity}}</t-tag>
          </view>

          <view class="sparkline {{item.deltaUp ? 'sparkline-rise' : 'sparkline-fall'}}"></view>
          <view class="delta-row">
            <t-tag size="small" theme="{{item.deltaUp ? 'success' : 'danger'}}" variant="light">
              {{item.deltaUp ? '▲' : '▼'}} {{item.delta}}
            </t-tag>
          </view>

          <view class="event-footer">
            <text class="footer-left">📊 成交量：{{item.volume}}</text>
            <t-button size="small" variant="text" theme="primary">查看原文</t-button>
            <t-button size="small" variant="text" theme="danger" catch:tap="onFavoriteTap">
              <t-icon name="heart" size="32rpx" />
            </t-button>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="tab-bar-wrap">
    <t-tab-bar value="{{tabValue}}" bind:change="onTabChange" fixed="{{true}}" placeholder="{{true}}" bordered="{{true}}">
      <t-tab-bar-item value="trending">热点</t-tab-bar-item>
      <t-tab-bar-item value="breaking">突发</t-tab-bar-item>
      <t-tab-bar-item value="latest">最新</t-tab-bar-item>
      <t-tab-bar-item value="whales">巨鲸</t-tab-bar-item>
      <t-tab-bar-item value="profile">我的</t-tab-bar-item>
    </t-tab-bar>
  </view>
</view>
