<view class="page-shell">
  <t-navbar title="📄 事件详情" left-arrow="{{true}}" fixed="{{true}}" placeholder="{{true}}" />

  <view class="content-wrap">
    <view class="top-info">
      <text class="top-clock">{{clockText}}</text>
      <t-button size="small" variant="outline" theme="primary" class="top-lang" bind:tap="onToggleLang">{{langBtnText}}</t-button>
    </view>

    <view class="event-card">
      <view class="event-body">
        <view class="event-title">{{title}}</view>
        <view class="event-meta">
          <t-tag size="small" variant="light">来源：polymarket.com</t-tag>
          <t-tag size="small" variant="light">WebView 占位页</t-tag>
        </view>
        <t-divider />
        <t-empty description="点击下方按钮将在正式版打开 PolyMarket 原文">
          <t-button theme="primary" bind:tap="onOpenWebView">打开原文详情</t-button>
        </t-empty>
      </view>
    </view>
  </view>
</view>
