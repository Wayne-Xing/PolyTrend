.profile-user {
  padding: 24rpx;
  display: flex;
  align-items: center;
}

.profile-avatar-wrap {
  width: 92rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-avatar {
  --td-avatar-bg-color: linear-gradient(135deg, #1565c0 0%, #6bb8ff 100%);
  --td-avatar-color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
}

.profile-avatar-btn {
  width: 92rpx;
  height: 92rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  border: none;
  border-radius: 999rpx;
  background: transparent;
  overflow: hidden;
}

.profile-avatar-btn::after {
  border: none;
}

.profile-avatar-static {
  width: 92rpx;
  height: 92rpx;
}

.profile-meta {
  margin-left: 24rpx;
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
}

.profile-name {
  color: #1f2937;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.25;
}

.profile-edit-nickname-link {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.2;
}

.profile-link {
  margin-top: 16rpx;
}

.profile-settings {
  margin-top: 16rpx;
}
