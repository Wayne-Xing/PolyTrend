.profile-user {
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.profile-avatar {
  --td-avatar-bg-color: linear-gradient(135deg, #1565c0 0%, #6bb8ff 100%);
  --td-avatar-color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
}

.profile-meta {
  min-width: 0;
}

.profile-name {
  color: #1f2937;
  font-size: 32rpx;
  font-weight: 700;
}

.profile-sub {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 22rpx;
}

.profile-link {
  margin-top: 16rpx;
}

.profile-settings {
  margin-top: 16rpx;
}
