.fav-toolbar {
  padding: 12rpx 14rpx;
}

.fav-search {
  --td-search-input-height: 56rpx;
  --td-search-bg-color: #f2f5fa;
  --td-search-padding: 0 12rpx;
  --td-search-height: 56rpx;
  --td-search-font-size: 20rpx;
  --td-search-icon-size: 28rpx;
}

.fav-list {
  margin-top: 12rpx;
  display: grid;
  gap: 12rpx;
}

.fav-item {
  min-height: 146rpx;
  padding: 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  transition: transform 0.2s ease;
}

.fav-item--dragging {
  opacity: 0.7;
  transform: scale(0.985);
}

.fav-item__thumb {
  width: 132rpx;
  height: 132rpx;
  border-radius: 18rpx;
  border: 1px solid #d8e3f1;
  background-size: cover;
  background-position: center;
  flex-shrink: 0;
}

.fav-item__body {
  min-width: 0;
  flex: 1;
}

.fav-item__title {
  color: #1d2f45;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.fav-item__sub {
  margin-top: 6rpx;
  color: #7d90a6;
  font-size: 20rpx;
}

.fav-item__meta {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  color: #5f748d;
  font-size: 18rpx;
}

.fav-item__actions {
  width: 36rpx;
  height: 132rpx;
  position: relative;
  flex-shrink: 0;
}

.fav-item__favorite {
  position: absolute;
  left: 50%;
  top: 24%;
  transform: translate(-50%, -50%);
  width: 26rpx;
  height: 26rpx;
  color: #b5c2d0;
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.fav-item__favorite--active {
  color: #ff5d7f;
}

.fav-item__drag {
  position: absolute;
  left: 50%;
  top: 60%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 44rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #8ea1b6;
  font-size: 34rpx;
  line-height: 1;
  flex-shrink: 0;
}

.fav-swipe-delete {
  background: linear-gradient(135deg, #d32f2f 0%, #ef5350 100%);
  color: #ffffff;
  font-weight: 700;
  min-height: 146rpx;
  height: 100%;
  width: 96rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  white-space: pre-line;
  line-height: 1.1;
}
